# ============================================================
# Zableke — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# Base de datos (Neon / PostgreSQL)
DATABASE_URL=

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (Auth.js)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT — firma de sesiones (mínimo 32 chars, cambiar en producción)
JWT_SECRET=


# Google Forms API (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# MinIO (object storage para configs de formularios)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=
MINIO_BROWSER_REDIRECT_URL=https://TU_DOMINIO/minio

# Email (notificaciones)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
