# ============================================================
# Zableke — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://zableke:zableke_dev@localhost:5432/zableke?schema=public"
POSTGRES_USER=zableke
POSTGRES_PASSWORD=zableke_dev
POSTGRES_DB=zableke
DB_PORT=5432

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (Auth.js)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT — firma de sesiones (mínimo 32 chars, cambiar en producción)
JWT_SECRET=


# Email (notificaciones)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
